{
  "reconcileBalance": true,
  "firefly": {
    "limit": 1000
  },
  "identifyMethod": {
    "isracard": "identifier",
    "leumi": "hash",
    "visaCal": "identifier"
  },
  "currencySymbolMap": {
    "\u20aa": "ILS",
    "$": "USD",
    "\u20ac": "EUR"
  },
  "creditCardDesc": [
    {
      "desc": "\u05dc.\u05de\u05d0\u05e1\u05d8\u05e8\u05e7\u05e8\u05d3(\u05d9\u05e9)",
      "creditCard": "isracard"
    },
    {
      "desc": "\u05d9\u05e9\u05e8\u05d0\u05db\u05e8\u05d8-\u05d9",
      "creditCard": "isracard"
    },
    {
      "desc": "\u05d5\u05d9\u05d6\u05d4 \u05db.\u05d0.\u05dc-\u05d9",
      "creditCard": "visaCal"
    },
    {
      "desc": "\u05db\u05e8\u05d8\u05d9\u05e1\u05d9 \u05d0\u05e9\u05e8\u05d0\u05d9-\u05d9",
      "creditCard": "visaCal"
    },
    {
      "desc": "\u05de\u05e7\u05e1 \u05d0\u05d9\u05d8 \u05e4\u05d9\u05e0\u05e0-\u05d9",
      "creditCard": "max"
    }
  ],
  "scraper": {
    "parallel": true,
    "options": {
      "args": [
        "--disable-dev-shm-usage",
        "--no-sandbox",
        "--disable-gpu",
        "--disable-blink-features=AutomationControlled"
      ],
      "combineInstallments": false,
      "showBrowser": false,
      "outputData": {
        "enableTransactionsFilterByDate": false
      },
      "additionalTransactionInformation": true
    }
  },
  "log": {
    "level": "info",
    "prettyPrint": true,
    "redact": [
      "error.config.headers.Authorization",
      "banks[*].credentials",
      "banks[*].credentials.username",
      "banks[*].credentials.password",
      "banks[*].credentials.id",
      "banks[*].credentials.userCode",
      "banks[*].credentials.card6Digits",
      "banks[*].creditCards[*].credentials",
      "banks[*].creditCards[*].credentials.username",
      "banks[*].creditCards[*].credentials.password",
      "banks[*].creditCards[*].credentials.id",
      "banks[*].creditCards[*].credentials.card6Digits",
      "firefly.tokenApi",
      "*.password",
      "*.credentials",
      "*.tokenApi",
      "*.token",
      "*.secret",
      "*.apiKey",
      "error.*.password",
      "error.*.credentials",
      "error.*.tokenApi"
    ]
  }
}